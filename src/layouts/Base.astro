---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Mario Inostroza — Software Engineer & AI Builder',
  description = 'Desarrollador Fullstack · AI Builder · Puerto Natales, Patagonia'
} = Astro.props;
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Mario Inostroza" />
    <meta name="theme-color" content="#0A0A0F" />
    <meta name="color-scheme" content="dark" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body class="min-h-dvh antialiased overflow-x-hidden">
    <a href="#main" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:px-4 focus:py-2 focus:bg-orange-500 focus:text-white focus:rounded-lg">
      Skip al contenido
    </a>

    <nav id="nav" class="fixed top-0 w-full z-50 border-b border-[var(--border-subtle)]">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 h-14 flex items-center justify-between">
        <a href="/" class="text-lg font-bold tracking-tight" style="font-family: var(--font-heading)">
          <span class="text-gradient">MI</span>
        </a>
        <div class="hidden md:flex items-center gap-8">
          <a href="/#proyectos" class="text-sm text-[var(--text-secondary)] hover:text-[var(--text-primary)] transition-colors duration-200">Proyectos</a>
          <a href="/#stack" class="text-sm text-[var(--text-secondary)] hover:text-[var(--text-primary)] transition-colors duration-200">Stack</a>
          <a href="/news" class="text-sm text-[var(--text-secondary)] hover:text-[var(--text-primary)] transition-colors duration-200">Noticias</a>
          <a href="/#contacto" class="text-sm text-[var(--text-secondary)] hover:text-[var(--text-primary)] transition-colors duration-200">Contacto</a>
        </div>
        <button id="menu-toggle" class="md:hidden p-2 text-[var(--text-secondary)] hover:text-[var(--text-primary)] cursor-pointer" aria-label="Abrir menu">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        </button>
      </div>
      <div id="mobile-menu" class="hidden md:hidden border-t border-[var(--border-subtle)]">
        <div class="px-4 py-4 flex flex-col gap-4" style="background: rgba(10,10,15,0.95); backdrop-filter: blur(16px);">
          <a href="/#proyectos" class="text-sm text-[var(--text-secondary)] hover:text-[var(--text-primary)] py-2 mobile-link">Proyectos</a>
          <a href="/#stack" class="text-sm text-[var(--text-secondary)] hover:text-[var(--text-primary)] py-2 mobile-link">Stack</a>
          <a href="/news" class="text-sm text-[var(--text-secondary)] hover:text-[var(--text-primary)] py-2 mobile-link">Noticias</a>
          <a href="/#contacto" class="text-sm text-[var(--text-secondary)] hover:text-[var(--text-primary)] py-2 mobile-link">Contacto</a>
        </div>
      </div>
    </nav>

    <main id="main" class="pt-14">
      <slot />
    </main>

    <footer class="border-t border-[var(--border-subtle)] py-10 px-4 mt-20">
      <div class="max-w-6xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4">
        <p class="text-sm text-[var(--text-muted)]">
          &copy; 2026 Mario Inostroza &middot; Puerto Natales, Patagonia
        </p>
        <div class="flex items-center gap-5">
          <a href="https://github.com/marioinostroza" target="_blank" rel="noopener noreferrer" aria-label="GitHub" class="text-[var(--text-muted)] hover:text-[var(--text-primary)] transition-colors">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          </a>
          <a href="https://linkedin.com/in/marioinostroza" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="text-[var(--text-muted)] hover:text-[var(--text-primary)] transition-colors">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
        </div>
        <p class="text-xs text-[var(--text-faint)]">Hecho con Astro</p>
      </div>
    </footer>

    <script>
      const toggle = document.getElementById('menu-toggle');
      const menu = document.getElementById('mobile-menu');
      const nav = document.getElementById('nav');

      toggle?.addEventListener('click', () => menu?.classList.toggle('hidden'));

      document.querySelectorAll('.mobile-link').forEach(link =>
        link.addEventListener('click', () => menu?.classList.add('hidden'))
      );

      let ticking = false;
      window.addEventListener('scroll', () => {
        if (!ticking) {
          requestAnimationFrame(() => {
            if (window.scrollY > 20) {
              nav.style.background = 'rgba(10,10,15,0.9)';
              nav.style.backdropFilter = 'blur(16px)';
            } else {
              nav.style.background = '';
              nav.style.backdropFilter = '';
            }
            ticking = false;
          });
          ticking = true;
        }
      }, { passive: true });
    </script>
  </body>
</html>
