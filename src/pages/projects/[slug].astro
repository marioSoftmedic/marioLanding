---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const initials = project.data.title.split(' ').map((w) => w[0]).join('').toUpperCase().slice(0, 2);
---

<Base title={`${project.data.title} — Mario Inostroza`} description={project.data.description}>
  <article class="max-w-4xl mx-auto px-4 sm:px-6 py-16">
    <a href="/#proyectos" class="btn-outline inline-flex items-center gap-2 px-4 py-2 text-sm rounded-lg cursor-pointer">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
      Volver a proyectos
    </a>

    <header class="mt-8 mb-12">
      <div class="flex items-start gap-5 mb-6">
        <div class="w-16 h-16 rounded-xl flex items-center justify-center text-gradient" style="font-family: var(--font-heading); font-size: 1.25rem; font-weight: 700;">
          {initials}
        </div>
        <div>
          <h1 class="text-3xl sm:text-4xl font-bold tracking-tight" style="color: var(--text-primary);">{project.data.title}</h1>
          <p class="text-lg mt-2" style="color: var(--text-muted);">{project.data.description}</p>
        </div>
      </div>

      <div class="flex flex-wrap gap-2 mt-6">
        {project.data.techStack.map((tech: string) => (
          <span class="px-3 py-1.5 text-xs font-medium rounded-lg" style="background: var(--bg-surface); border: 1px solid var(--border-subtle); color: var(--text-muted);">{tech}</span>
        ))}
      </div>

      <div class="flex gap-3 mt-8">
        {project.data.githubUrl && (
          <a href={project.data.githubUrl} target="_blank" rel="noopener noreferrer" aria-label="GitHub (se abre en nueva pestaña)"
            class="btn-outline inline-flex items-center gap-2 px-5 py-3 text-sm font-medium rounded-xl cursor-pointer"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            GitHub
          </a>
        )}
        {project.data.demoUrl && (
          <a href={project.data.demoUrl} target="_blank" rel="noopener noreferrer" aria-label="Ver Demo (se abre en nueva pestaña)"
            class="btn-primary inline-flex items-center gap-2 px-5 py-3 text-sm rounded-xl cursor-pointer"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
            Website
          </a>
        )}
      </div>
    </header>

    <div class="prose max-w-none">
      <Content />
    </div>
  </article>
</Base>
