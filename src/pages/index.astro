---
import Base from '../layouts/Base.astro';
import NewsFeed from '../components/NewsFeed.tsx';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');
---

<Base>
  <section class="min-h-dvh flex items-center justify-center relative overflow-hidden" aria-label="Presentación">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-0 left-1/4 w-[600px] h-[600px] rounded-full opacity-25 blur-[140px]" style="background: radial-gradient(circle, var(--accent-orange), transparent 70%); animation: float 8s ease-in-out infinite;"></div>
      <div class="absolute bottom-1/4 right-1/4 w-[500px] h-[500px] rounded-full opacity-20 blur-[120px]" style="background: radial-gradient(circle, var(--accent-cyan), transparent 70%); animation: float 10s ease-in-out infinite 2s;"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] rounded-full opacity-[0.1] blur-[160px]" style="background: radial-gradient(circle, var(--accent-orange), var(--accent-cyan), transparent 70%);"></div>
    </div>

    <div class="absolute inset-0 pointer-events-none opacity-[0.03]" style="background-image: linear-gradient(var(--text-primary) 1px, transparent 1px), linear-gradient(90deg, var(--text-primary) 1px, transparent 1px); background-size: 60px 60px;"></div>

    <div class="relative z-10 max-w-6xl mx-auto px-4 animate-fade-in">
      <div class="flex flex-col-reverse md:flex-row items-center gap-10 md:gap-16">

        <div class="text-center md:text-left flex-1">
          <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-[var(--border-default)] bg-[var(--bg-elevated)] mb-6">
            <span class="w-2 h-2 rounded-full bg-[var(--accent-green)]" style="animation: pulse 2s ease-in-out infinite;"></span>
            <span class="text-xs font-medium tracking-wide" style="color: var(--text-secondary);">Disponible para proyectos</span>
          </div>

          <h1 class="text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-bold tracking-tighter leading-none">
            <span class="block" style="color: var(--text-primary);">Mario</span>
            <span class="text-gradient">Inostroza</span>
          </h1>

          <p class="text-lg sm:text-xl md:text-2xl mt-6 max-w-xl leading-relaxed" style="color: var(--text-secondary);">
            Software Engineer &amp; AI Builder
            <br />
            <span style="color: var(--text-muted);">desde Puerto Natales, Patagonia</span>
          </p>

          <div class="flex flex-wrap items-center justify-center md:justify-start gap-3 mt-10">
            <a href="#proyectos"
              class="btn-primary inline-flex items-center gap-2 px-7 py-3.5 text-sm rounded-xl cursor-pointer"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
              Ver proyectos
            </a>
            <a href="#contacto"
              class="btn-outline inline-flex items-center gap-2 px-7 py-3.5 text-sm font-medium rounded-xl cursor-pointer"
            >
              Contactar
            </a>
          </div>
        </div>

        <div class="relative flex-shrink-0">
          <div class="hero-image-wrapper">
            <img
              src="/img/marioHealthBits4.png"
              alt="Mario Inostroza — Software Engineer & AI Builder"
              width="320"
              height="400"
              loading="eager"
              decoding="async"
            />
          </div>
        </div>

      </div>

      <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-float hidden sm:block">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="color: var(--text-faint);"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
      </div>
    </div>
  </section>

  <section id="proyectos" class="py-24 px-4" aria-labelledby="proyectos-title">
    <div class="max-w-6xl mx-auto">
      <div class="mb-12">
        <p class="text-xs font-medium tracking-widest uppercase mb-3" style="color: var(--accent-orange);">Portafolio</p>
        <h2 id="proyectos-title" class="text-3xl sm:text-4xl font-bold tracking-tight">Proyectos</h2>
        <p class="mt-3 text-lg" style="color: var(--text-muted);">Agentes de IA, bots conversacionales y sistemas autónomos</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {projects.map((project) => {
          const href = `/projects/${project.id}`;
          const initials = project.data.title.split(' ').map((w) => w[0]).join('').toUpperCase().slice(0, 2);

          return (
            <a
              href={href}
              aria-label={project.data.title}
              class="glass-card group block overflow-hidden cursor-pointer"
            >
              <div class="relative h-40 flex items-center justify-center overflow-hidden" style="background: linear-gradient(135deg, var(--bg-elevated), var(--bg-surface));">
                {project.data.image ? (
                  <>
                    <img
                      src={project.data.image}
                      alt=""
                      aria-hidden="true"
                      class="absolute inset-0 w-full h-full object-cover object-top transition-transform duration-500 group-hover:scale-105"
                      style="opacity: 0.55;"
                      loading="lazy"
                    />
                    <div class="absolute inset-0" style="background: linear-gradient(to bottom, rgba(10,10,15,0.1) 0%, rgba(10,10,15,0.7) 100%);"></div>
                  </>
                ) : (
                  <span class="text-3xl font-bold tracking-tight transition-transform duration-300 group-hover:scale-110 text-gradient" style="font-family: var(--font-heading);">{initials}</span>
                )}
                <div class="absolute bottom-0 left-0 right-0 h-[2px]" style="background: linear-gradient(90deg, var(--accent-orange), var(--accent-cyan)); opacity: 0.5;"></div>
              </div>

              <div class="p-5">
                <h3 class="text-lg font-semibold mb-1.5" style="color: var(--text-primary);">{project.data.title}</h3>
                <p class="text-sm mb-4 line-clamp-2" style="color: var(--text-muted);">{project.data.description}</p>
                <div class="flex flex-wrap gap-1.5">
                  {project.data.techStack.slice(0, 4).map((tech) => (
                    <span class="px-2.5 py-1 text-xs rounded-md font-medium" style="background: var(--bg-elevated); color: var(--text-muted); border: 1px solid var(--border-subtle);">{tech}</span>
                  ))}
                </div>
              </div>
            </a>
          );
        })}
      </div>

      <div class="mt-14 pt-10 border-t border-[var(--border-subtle)]">
        <p class="text-xs font-medium tracking-widest uppercase mb-6 text-center" style="color: var(--text-faint);">Especialidades</p>
        <div class="flex flex-wrap justify-center gap-3">
          {[
            { icon: '🤖', label: 'AI Agents', desc: 'Agentes autónomos con tool use' },
            { icon: '🐙', label: 'Agent Squads', desc: 'Orquestación multi-agente' },
            { icon: '💬', label: 'WhatsApp & Telegram Bots', desc: 'Bots conversacionales con LLMs' },
            { icon: '🧠', label: 'Memoria Semántica', desc: 'pgvector + embeddings' },
            { icon: '🔌', label: 'MCP / Tool Use', desc: 'Integración de herramientas y APIs' },
            { icon: '⚡', label: 'Automatización', desc: 'Workflows y triggers autónomos' },
          ].map((s) => (
            <div class="flex items-center gap-2.5 px-4 py-2.5 rounded-xl" style="background: var(--bg-elevated); border: 1px solid var(--border-subtle);">
              <span style="font-size: 1rem; line-height: 1;">{s.icon}</span>
              <div>
                <p class="text-sm font-medium" style="color: var(--text-primary); line-height: 1.2;">{s.label}</p>
                <p class="text-xs" style="color: var(--text-faint); line-height: 1.3;">{s.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section id="stack" class="py-24 px-4" aria-labelledby="stack-title">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-14">
        <p class="text-xs font-medium tracking-widest uppercase mb-3" style="color: var(--accent-cyan);">Herramientas</p>
        <h2 id="stack-title" class="text-3xl sm:text-4xl font-bold tracking-tight">Stack Técnico</h2>
        <p class="mt-3 text-lg" style="color: var(--text-muted);">Fullstack · IA · Agentes autónomos</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {[
          {
            label: 'Frontend',
            color: 'var(--accent-cyan)',
            icon: '<path d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>',
            items: ['TypeScript', 'React', 'Next.js', 'Astro', 'Tailwind CSS'],
          },
          {
            label: 'Backend & Datos',
            color: 'var(--accent-orange)',
            icon: '<ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5v14a9 3 0 0018 0V5"/><path d="M3 12a9 3 0 0018 0"/>',
            items: ['Node.js', 'PostgreSQL', 'pgvector', 'Drizzle ORM', 'Git'],
          },
          {
            label: 'IA & Agentes',
            color: 'var(--accent-green)',
            icon: '<path d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>',
            items: ['Anthropic Claude', 'GLM-5', 'Kimi K2', 'Gemini', 'OpenClaw', 'MCP', 'WhatsApp API', 'Telegram API'],
          },
        ].map((group) => (
          <div class="glass-card p-6">
            <div class="flex items-center gap-3 mb-5">
              <div class="w-8 h-8 rounded-lg flex items-center justify-center" style={`background: color-mix(in srgb, ${group.color} 15%, transparent); border: 1px solid color-mix(in srgb, ${group.color} 30%, transparent);`}>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style={`color: ${group.color};`} set:html={group.icon} />
              </div>
              <h3 class="text-sm font-semibold tracking-wide" style={`color: ${group.color};`}>{group.label}</h3>
            </div>
            <div class="flex flex-wrap gap-2">
              {group.items.map((tech) => (
                <span class="px-3 py-1.5 text-xs font-medium rounded-lg" style="background: var(--bg-elevated); border: 1px solid var(--border-subtle); color: var(--text-secondary);">{tech}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-24 px-4" aria-labelledby="news-title">
    <div class="max-w-6xl mx-auto">
      <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mb-10">
        <div>
          <p class="text-xs font-medium tracking-widest uppercase mb-3" style="color: var(--accent-orange);">Feed</p>
          <h2 id="news-title" class="text-3xl sm:text-4xl font-bold tracking-tight">Noticias de IA</h2>
          <p class="mt-2" style="color: var(--text-muted);">Últimas novedades en inteligencia artificial</p>
        </div>
        <a href="/news" class="btn-outline inline-flex items-center gap-2 px-4 py-2 text-sm font-medium rounded-lg cursor-pointer"
          style="color: var(--accent-orange); border-color: var(--accent-orange-glow); background: var(--accent-orange-glow);"
        >
          Ver todas
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>

      <NewsFeed client:load limit={6} />
    </div>
  </section>

  <section id="contacto" class="py-24 px-4" aria-labelledby="contacto-title">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-xs font-medium tracking-widest uppercase mb-3" style="color: var(--accent-cyan);">Contacto</p>
      <h2 id="contacto-title" class="text-3xl sm:text-4xl font-bold tracking-tight mb-4">¿Trabajamos juntos?</h2>
      <p class="text-lg mb-10" style="color: var(--text-muted);">Si tienes un proyecto en mente, charlemos.</p>

      <div class="flex flex-wrap items-center justify-center gap-4">
        <a href="mailto:mario.inostroza.m@gmail.com"
          class="btn-outline inline-flex items-center gap-3 px-6 py-3.5 text-sm font-medium rounded-xl cursor-pointer"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          Email
        </a>
        <a href="https://wa.me/56962170366" target="_blank" rel="noopener noreferrer" aria-label="WhatsApp (se abre en nueva pestaña)"
          class="btn-outline inline-flex items-center gap-3 px-6 py-3.5 text-sm font-medium rounded-xl cursor-pointer"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
          WhatsApp
        </a>
        <a href="https://x.com/marioHealthBits" target="_blank" rel="noopener noreferrer" aria-label="X / Twitter (se abre en nueva pestaña)"
          class="btn-outline inline-flex items-center gap-3 px-6 py-3.5 text-sm font-medium rounded-xl cursor-pointer"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.748l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          X
        </a>
        <a href="https://github.com/marioinostroza" target="_blank" rel="noopener noreferrer" aria-label="GitHub (se abre en nueva pestaña)"
          class="btn-outline inline-flex items-center gap-3 px-6 py-3.5 text-sm font-medium rounded-xl cursor-pointer"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          GitHub
        </a>
        <a href="https://www.linkedin.com/in/mario-inostroza-softmedic/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn (se abre en nueva pestaña)"
          class="btn-outline inline-flex items-center gap-3 px-6 py-3.5 text-sm font-medium rounded-xl cursor-pointer"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          LinkedIn
        </a>
      </div>
    </div>
  </section>
</Base>
