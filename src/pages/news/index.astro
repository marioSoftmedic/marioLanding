---
import Base from '../../layouts/Base.astro'
import NewsFeed from '../../components/NewsFeed.tsx'

---

<Base title="Noticias de IA — Mario Inostroza" description="Últimas noticias del mundo de la inteligencia artificial, agentes de IA y tecnología.">
  <section class="max-w-6xl mx-auto px-4 sm:px-6 py-16" aria-labelledby="news-title">
    <a href="/" class="btn-outline inline-flex items-center gap-2 px-4 py-2 text-sm rounded-lg cursor-pointer">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
      Volver al inicio
    </a>

    <div class="mt-8 mb-10">
      <p class="text-xs font-medium tracking-widest uppercase mb-3" style="color: var(--accent-orange);">Feed</p>
      <h1 id="news-title" class="text-3xl sm:text-4xl font-bold tracking-tight">Noticias de IA</h1>
      <p class="mt-3 text-lg" style="color: var(--text-muted);">Últimas novedades del mundo de la inteligencia artificial, recopiladas automáticamente.</p>
    </div>

    <NewsFeed client:load />
  </section>
</Base>
