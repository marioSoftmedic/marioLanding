---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const posts = allPosts
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const formatDate = (date: Date) =>
  date.toLocaleDateString('es-CL', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Base title="Blog — Mario Inostroza" description="Artículos sobre IA, agentes autónomos y desarrollo de software desde la Patagonia.">
  <section class="py-24 px-4">
    <div class="max-w-3xl mx-auto">

      <div class="mb-14">
        <p class="text-xs font-medium tracking-widest uppercase mb-3" style="color: var(--accent-orange);">Escritura</p>
        <h1 class="text-4xl sm:text-5xl font-bold tracking-tight">Blog</h1>
        <p class="mt-3 text-lg" style="color: var(--text-muted);">IA, agentes y lo que aprendo construyendo desde la Patagonia.</p>
      </div>

      {posts.length === 0 ? (
        <div class="text-center py-20">
          <p class="text-lg" style="color: var(--text-faint);">Próximamente — el primer post está en camino.</p>
        </div>
      ) : (
        <div class="flex flex-col gap-1">
          {posts.map((post) => (
            <a
              href={`/blog/${post.id}`}
              class="group flex flex-col sm:flex-row sm:items-start gap-3 sm:gap-8 py-6 border-b border-[var(--border-subtle)] hover:border-[var(--border-default)] transition-colors duration-200"
            >
              <time
                datetime={post.data.date.toISOString()}
                class="text-sm shrink-0 pt-0.5 tabular-nums"
                style="color: var(--text-faint); min-width: 7rem;"
              >
                {formatDate(post.data.date)}
              </time>

              <div class="flex-1 min-w-0">
                <h2
                  class="text-lg font-semibold mb-1 group-hover:text-gradient transition-colors duration-200"
                  style="color: var(--text-primary);"
                >
                  {post.data.title}
                </h2>
                <p class="text-sm line-clamp-2 mb-3" style="color: var(--text-muted);">
                  {post.data.description}
                </p>
                {post.data.tags.length > 0 && (
                  <div class="flex flex-wrap gap-1.5">
                    {post.data.tags.map((tag) => (
                      <span
                        class="px-2 py-0.5 text-xs rounded-md font-medium"
                        style="background: var(--bg-elevated); color: var(--text-faint); border: 1px solid var(--border-subtle);"
                      >
                        {tag}
                      </span>
                    ))}
                  </div>
                )}
              </div>

              <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="shrink-0 mt-1.5 opacity-0 group-hover:opacity-100 transition-opacity duration-200 hidden sm:block"
                style="color: var(--accent-orange);"
              >
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </a>
          ))}
        </div>
      )}

    </div>
  </section>
</Base>
