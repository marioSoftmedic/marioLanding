---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { HUBS, hubPath, postsForHub } from '../lib/hubs';
import { tagsForPost, tagDisplay } from '../lib/tags';
import NewsletterSignup from '../components/NewsletterSignup.astro';

export async function getStaticPaths() {
  return HUBS.map((hub) => ({
    params: { hub: hub.slug.es },
    props: { hub },
  }));
}

const { hub } = Astro.props;
const lang = 'es' as const;
const allPosts = await getCollection('blog');
const hubPosts = postsForHub(allPosts, hub, lang);
const siteUrl = 'https://mariohealthbits.dev';
const canonicalUrl = `${siteUrl}${hubPath(hub, lang)}`;
const alternatePath = hubPath(hub, 'en');

const formatDate = (date: Date) =>
  date.toLocaleDateString('es-CL', { year: 'numeric', month: 'long', day: 'numeric' });

const schema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: `${hub.title[lang]} — Mario Inostroza`,
  description: hub.description[lang],
  url: canonicalUrl,
  inLanguage: 'es-CL',
  about: hub.keywords,
  isPartOf: {
    '@type': 'Blog',
    name: 'Blog — Mario Inostroza',
    url: `${siteUrl}/blog`,
  },
};
---

<Base title={`${hub.title[lang]} — Mario Inostroza`} description={hub.description[lang]} schema={schema} alternatePath={alternatePath}>
  <section class="py-24 px-4">
    <div class="max-w-4xl mx-auto">
      <a href="/blog" class="inline-flex items-center gap-2 text-sm mb-10 transition-colors duration-200" style="color: var(--text-faint);">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        Blog
      </a>

      <header class="mb-12">
        <p class="text-xs font-medium tracking-widest uppercase mb-3" style="color: var(--accent-orange);">{hub.eyebrow[lang]}</p>
        <h1 class="text-4xl sm:text-5xl font-bold tracking-tight mb-5">{hub.title[lang]}</h1>
        <p class="text-lg leading-relaxed max-w-3xl" style="color: var(--text-muted);">{hub.description[lang]}</p>
        <div class="flex flex-wrap gap-2 mt-6">
          {hub.keywords.map((keyword) => (
            <span class="px-3 py-1.5 text-xs rounded-lg" style="background: var(--bg-elevated); color: var(--text-muted); border: 1px solid var(--border-subtle);">{keyword}</span>
          ))}
        </div>
      </header>

      <div class="mb-12">
        <NewsletterSignup lang={lang} tags={hub.tags} newsletterTopic={hub.id} source={`hub-${hub.id}`} />
      </div>

      {hubPosts.length === 0 ? (
        <p class="py-12 text-center" style="color: var(--text-muted);">Todavía no hay posts publicados para este hub.</p>
      ) : (
        <div class="flex flex-col gap-1">
          {hubPosts.map(({ post, matchingTags }) => {
            const slug = post.data.canonicalSlug ?? post.id.replace(/\.en$/, '');
            return (
              <a href={`/blog/${slug}`} class="group block py-6 border-b border-[var(--border-subtle)] hover:border-[var(--border-default)] transition-colors duration-200">
                <time datetime={post.data.date.toISOString()} class="text-sm tabular-nums" style="color: var(--text-faint);">{formatDate(post.data.date)}</time>
                <h2 class="text-xl font-semibold mt-2 mb-2 group-hover:text-gradient transition-colors duration-200" style="color: var(--text-primary);">{post.data.title}</h2>
                <p class="text-sm line-clamp-2 mb-3" style="color: var(--text-muted);">{post.data.description}</p>
                <div class="flex flex-wrap gap-1.5">
                  {matchingTags.map((tag) => (
                    <span class="px-2 py-0.5 text-xs rounded-md font-medium" style="background: var(--accent-orange-glow); color: var(--accent-orange); border: 1px solid color-mix(in srgb, var(--accent-orange) 25%, transparent);">{tagDisplay(tag, lang)}</span>
                  ))}
                  {tagsForPost(post.data.tags).filter((tag) => !matchingTags.includes(tag)).slice(0, 3).map((tag) => (
                    <span class="px-2 py-0.5 text-xs rounded-md font-medium" style="background: var(--bg-elevated); color: var(--text-faint); border: 1px solid var(--border-subtle);">{tagDisplay(tag, lang)}</span>
                  ))}
                </div>
              </a>
            );
          })}
        </div>
      )}
    </div>
  </section>
</Base>
