---
import type { Lang } from '../lib/tags';
import { ctaForPost } from '../lib/ctas';

interface Props {
  lang?: Lang;
  tags?: string[];
  leadMagnet?: string;
  newsletterTopic?: string;
  source?: string;
  compact?: boolean;
}

const {
  lang = 'es',
  tags = [],
  leadMagnet,
  newsletterTopic,
  source = 'site',
  compact = false,
} = Astro.props;

const cta = ctaForPost({ lang, tags, leadMagnet, newsletterTopic });
const BREVO_DEFAULT_FORM_ACTION = 'https://92f7ef8b.sibforms.com/serve/MUIFAMRsCMDJd7_Dvzk6TWE7glb-9dyNcM_JCDZiETsrmKIZ75HvVFvTJ5uw2jcc3GqbZcy5N5Hwde2L7u_H011117rzTUPE_4vQcGEsr8RnEI5vZ0H8H8GEuPnD1M9rhUth-yV1jFLdmr0sONwxCOY90zBbmNbXPSl9uhqmVE1h_-FMzHq980hDcMEzz4OCk6R45Sq1575x4D8ftQ==';
const embedUrl = import.meta.env.PUBLIC_NEWSLETTER_EMBED_URL;
const formAction = import.meta.env.PUBLIC_NEWSLETTER_FORM_ACTION ?? BREVO_DEFAULT_FORM_ACTION;
const fallbackHref = lang === 'es'
  ? 'https://wa.me/56962170366?text=Quiero%20recibir%20el%20Healthbits%20Brief'
  : 'https://wa.me/56962170366?text=I%20want%20to%20receive%20the%20Healthbits%20Brief';
const emailPlaceholder = lang === 'es' ? 'tu@email.com' : 'you@email.com';
const privacy = lang === 'es'
  ? 'Semanal, sin spam. Puedes darte de baja cuando quieras.'
  : 'Weekly, no spam. You can unsubscribe anytime.';
const fallbackLabel = lang === 'es' ? 'Pedir alta por WhatsApp' : 'Ask to join on WhatsApp';
const emailLabel = lang === 'es' ? 'Email para recibir el briefing' : 'Email to receive the brief';
const invalidMessage = lang === 'es'
  ? 'No hemos podido validar tu suscripción. Revisa el email e intenta nuevamente.'
  : 'We could not validate your subscription. Check the email and try again.';
const successMessage = lang === 'es'
  ? 'Listo. Revisa tu correo para confirmar la suscripción.'
  : 'Done. Check your email to confirm the subscription.';
const sendingMessage = lang === 'es'
  ? 'Enviando tu registro...'
  : 'Sending your signup...';
const localSuccessMessage = lang === 'es'
  ? 'Registro enviado. Revisa tu correo para confirmar la suscripción al Healthbits Brief.'
  : 'Signup sent. Check your email to confirm your Healthbits Brief subscription.';
---

<section class:list={['newsletter-card', compact && 'newsletter-card--compact']} aria-label={cta.title}>
  <div class="newsletter-card__copy">
    <p class="newsletter-card__eyebrow">Newsletter</p>
    <h2>{cta.title}</h2>
    <p>{cta.description}</p>
    <p class="newsletter-card__benefit">{cta.benefit}</p>
    <a href={cta.resourcePath} class="newsletter-card__resource">{cta.secondaryLabel}</a>
  </div>

  <div class="newsletter-card__form">
    {embedUrl ? (
      <iframe
        src={embedUrl}
        title={cta.title}
        loading="lazy"
        class="newsletter-card__iframe"
      ></iframe>
    ) : formAction ? (
      <div class="sib-form newsletter-card__sib-form">
        <div id="sib-form-container" class="sib-form-container">
          <div id="error-message" class="sib-form-message-panel newsletter-card__message newsletter-card__message--error">
            <div class="sib-form-message-panel__text sib-form-message-panel__text--center">
              <svg viewBox="0 0 512 512" class="sib-icon sib-notification__icon" aria-hidden="true">
                <path d="M256 40c118.621 0 216 96.075 216 216 0 119.291-96.61 216-216 216-119.244 0-216-96.562-216-216 0-119.203 96.602-216 216-216m0-32C119.043 8 8 119.083 8 256c0 136.997 111.043 248 248 248s248-111.003 248-248C504 119.083 392.957 8 256 8zm-11.49 120h22.979c6.823 0 12.274 5.682 11.99 12.5l-7 168c-.268 6.428-5.556 11.5-11.99 11.5h-8.979c-6.433 0-11.722-5.073-11.99-11.5l-7-168c-.283-6.818 5.167-12.5 11.99-12.5zM256 340c-15.464 0-28 12.536-28 28s12.536 28 28 28 28-12.536 28-28-12.536-28-28-28z" />
              </svg>
              <span class="sib-form-message-panel__inner-text">{invalidMessage}</span>
            </div>
          </div>
          <div id="success-message" class="sib-form-message-panel newsletter-card__message newsletter-card__message--success">
            <div class="sib-form-message-panel__text sib-form-message-panel__text--center">
              <svg viewBox="0 0 512 512" class="sib-icon sib-notification__icon" aria-hidden="true">
                <path d="M256 8C119.033 8 8 119.033 8 256s111.033 248 248 248 248-111.033 248-248S392.967 8 256 8zm0 464c-118.664 0-216-96.055-216-216 0-118.663 96.055-216 216-216 118.664 0 216 96.055 216 216 0 118.663-96.055 216-216 216zm141.63-274.961L217.15 376.071c-4.705 4.667-12.303 4.637-16.97-.068l-85.878-86.572c-4.667-4.705-4.637-12.303.068-16.97l8.52-8.451c4.705-4.667 12.303-4.637 16.97.068l68.976 69.533 163.441-162.13c4.705-4.667 12.303-4.637 16.97.068l8.451 8.52c4.668 4.705 4.637 12.303-.068 16.97z" />
              </svg>
              <span class="sib-form-message-panel__inner-text">{successMessage}</span>
            </div>
          </div>
          <div id="sib-container" class="sib-container--large sib-container--vertical newsletter-card__sib-container">
            <form id="sib-form" action={formAction} method="POST" class="newsletter-card__fields" data-type="subscription" data-source={source} data-topic={cta.topic}>
              <div class="sib-input sib-form-block">
                <div class="form__entry entry_block">
                  <div class="form__label-row">
                    <label class="sr-only entry__label" for="EMAIL" data-required="*">{emailLabel}</label>
                    <div class="entry__field">
                      <input class="input" id="EMAIL" type="text" name="EMAIL" placeholder={emailPlaceholder} autocomplete="email" data-required="true" required />
                    </div>
                  </div>
                  <label class="entry__error entry__error--primary newsletter-card__field-error"></label>
                </div>
              </div>
              <input type="text" name="email_address_check" value="" class="input--hidden" tabindex="-1" autocomplete="off" />
              <input type="hidden" name="locale" value={lang} />
              <button class="sib-form-block__button sib-form-block__button-with-loader" form="sib-form" type="submit" data-default-label={cta.buttonLabel} data-sending-label={sendingMessage}>
                <svg class="icon clickable__icon progress-indicator__icon sib-hide-loader-icon" viewBox="0 0 512 512" aria-hidden="true">
                  <path d="M460.116 373.846l-20.823-12.022c-5.541-3.199-7.54-10.159-4.663-15.874 30.137-59.886 28.343-131.652-5.386-189.946-33.641-58.394-94.896-95.833-161.827-99.676C261.028 55.961 256 50.751 256 44.352V20.309c0-6.904 5.808-12.337 12.703-11.982 83.556 4.306 160.163 50.864 202.11 123.677 42.063 72.696 44.079 162.316 6.031 236.832-3.14 6.148-10.75 8.461-16.728 5.01z" />
                </svg>
                <span class="newsletter-card__button-label">{cta.buttonLabel}</span>
              </button>
            </form>
            <div class="newsletter-card__local-status" data-newsletter-local-status aria-live="polite" hidden>
              {localSuccessMessage}
            </div>
          </div>
        </div>
      </div>
    ) : (
      <div class="newsletter-card__fallback">
        <p>{lang === 'es' ? 'Mientras abrimos el alta automática, puedes pedir que te sume manualmente.' : 'While automatic signup opens, you can ask me to add you manually.'}</p>
        <a href={fallbackHref} target="_blank" rel="noopener noreferrer">{fallbackLabel}</a>
      </div>
    )}
    <p class="newsletter-card__privacy">{privacy}</p>
  </div>
</section>

<style>
  .newsletter-card {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(260px, 0.9fr);
    gap: 1.5rem;
    padding: 1.5rem;
    border-radius: 1.25rem;
    border: 1px solid color-mix(in srgb, var(--accent-orange) 24%, var(--border-subtle));
    background:
      radial-gradient(circle at top left, color-mix(in srgb, var(--accent-orange) 18%, transparent), transparent 34%),
      linear-gradient(135deg, var(--bg-elevated), var(--bg-surface));
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.18);
  }

  .newsletter-card--compact {
    grid-template-columns: 1fr;
  }

  .newsletter-card__eyebrow {
    margin: 0 0 0.6rem;
    color: var(--accent-orange);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .newsletter-card h2 {
    margin: 0 0 0.75rem;
    color: var(--text-primary);
    font-family: var(--font-heading);
    font-size: clamp(1.35rem, 2vw, 1.75rem);
    line-height: 1.15;
    letter-spacing: -0.03em;
  }

  .newsletter-card p {
    margin: 0;
    color: var(--text-muted);
    line-height: 1.65;
  }

  .newsletter-card__benefit {
    margin-top: 0.75rem !important;
    color: var(--text-secondary) !important;
  }

  .newsletter-card__resource {
    display: inline-flex;
    margin-top: 1rem;
    color: var(--accent-orange);
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
  }

  .newsletter-card__resource:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .newsletter-card__form {
    align-self: center;
  }

  .newsletter-card__sib-form,
  .newsletter-card__sib-container {
    margin: 0;
    padding: 0;
    background: transparent;
    border: 0;
    max-width: none;
    text-align: left;
  }

  .newsletter-card__fields {
    display: grid;
    gap: 0.7rem;
  }

  .newsletter-card__message {
    display: none;
    margin-bottom: 0.75rem;
    padding: 0.75rem 0.85rem;
    border-radius: 0.8rem;
    font-size: 0.9rem;
    line-height: 1.45;
    text-align: left;
  }

  .newsletter-card__message--error {
    color: #ffd6d6;
    background: rgba(255, 73, 73, 0.12);
    border: 1px solid rgba(255, 73, 73, 0.35);
  }

  .newsletter-card__message--success {
    color: #c6f6d5;
    background: rgba(19, 206, 102, 0.12);
    border: 1px solid rgba(19, 206, 102, 0.35);
  }

  .newsletter-card .sib-form-message-panel__text {
    display: flex;
    align-items: center;
    gap: 0.55rem;
  }

  .newsletter-card .sib-notification__icon {
    width: 18px;
    height: 18px;
    flex: 0 0 auto;
    fill: currentColor;
  }

  .newsletter-card input {
    width: 100%;
    min-height: 46px;
    border-radius: 0.8rem;
    border: 1px solid var(--border-subtle);
    background: rgba(255, 255, 255, 0.04);
    color: var(--text-primary);
    padding: 0 0.9rem;
    outline: none;
  }

  .newsletter-card input:focus {
    border-color: color-mix(in srgb, var(--accent-orange) 55%, var(--border-subtle));
  }

  .newsletter-card .input--hidden {
    display: none;
  }

  .newsletter-card .sib-input,
  .newsletter-card .sib-form-block,
  .newsletter-card .form__entry,
  .newsletter-card .form__label-row,
  .newsletter-card .entry__field {
    margin: 0;
    padding: 0;
  }

  .newsletter-card__field-error {
    display: block;
    min-height: 0;
    color: #ffd6d6;
    font-size: 0.78rem;
    line-height: 1.4;
  }

  .newsletter-card__local-status {
    margin-top: 0.85rem;
    padding: 0.85rem 0.95rem;
    border-radius: 0.85rem;
    color: #c6f6d5;
    background: rgba(19, 206, 102, 0.12);
    border: 1px solid rgba(19, 206, 102, 0.35);
    font-size: 0.92rem;
    line-height: 1.5;
  }

  .newsletter-card__local-status[hidden] {
    display: none;
  }

  .newsletter-card button,
  .newsletter-card__fallback a {
    display: inline-flex;
    justify-content: center;
    align-items: center;
    min-height: 46px;
    border: 0;
    border-radius: 0.8rem;
    background: linear-gradient(135deg, var(--accent-orange), #ff7a1a);
    color: #0a0a0f;
    font-weight: 800;
    cursor: pointer;
    text-decoration: none;
    padding: 0 1rem;
  }

  .newsletter-card .progress-indicator__icon {
    display: none;
    width: 16px;
    height: 16px;
    margin-right: 0.45rem;
    fill: currentColor;
  }

  .newsletter-card .progress-indicator__icon:not(.sib-hide-loader-icon),
  .newsletter-card button[data-state="sending"] .progress-indicator__icon {
    display: inline-block;
    animation: newsletter-spin 0.9s linear infinite;
  }

  @keyframes newsletter-spin {
    to { transform: rotate(360deg); }
  }

  .newsletter-card__fallback {
    display: grid;
    gap: 0.85rem;
    padding: 1rem;
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--border-subtle);
  }

  .newsletter-card__fallback p {
    font-size: 0.92rem;
  }

  .newsletter-card__iframe {
    width: 100%;
    min-height: 320px;
    border: 0;
    border-radius: 1rem;
    background: transparent;
  }

  .newsletter-card__privacy {
    margin-top: 0.75rem !important;
    color: var(--text-faint) !important;
    font-size: 0.78rem;
  }

  @media (max-width: 760px) {
    .newsletter-card {
      grid-template-columns: 1fr;
      padding: 1.15rem;
    }
  }
</style>

<script is:inline>
  window.REQUIRED_CODE_ERROR_MESSAGE = 'Elige un código de país';
  window.LOCALE = 'es';
  window.EMAIL_INVALID_MESSAGE = window.SMS_INVALID_MESSAGE = 'La información que has proporcionado no es válida. Comprueba el formato del campo e inténtalo de nuevo.';
  window.REQUIRED_ERROR_MESSAGE = 'Este campo no puede quedar vacío.';
  window.GENERIC_INVALID_MESSAGE = 'La información que has proporcionado no es válida. Comprueba el formato del campo e inténtalo de nuevo.';
  window.INVALID_NUMBER = 'La información que has proporcionado no es válida. Comprueba el formato del campo e inténtalo de nuevo.';
  window.INVALID_DATE = 'Introduce una fecha válida';
  window.REQUIRED_MULTISELECT_MESSAGE = 'Selecciona al menos una opción';
  window.translation = {
    common: {
      selectedList: '{quantity} lista seleccionada',
      selectedLists: '{quantity} listas seleccionadas',
      selectedOption: '{quantity} seleccionado',
      selectedOptions: '{quantity} seleccionados',
    },
  };
  var AUTOHIDE = Boolean(0);

  document.querySelectorAll('.newsletter-card').forEach((card) => {
    const form = card.querySelector('#sib-form');
    const email = card.querySelector('input[name="EMAIL"]');
    const button = card.querySelector('button[type="submit"]');
    const buttonLabel = button?.querySelector('.newsletter-card__button-label');
    const localStatus = card.querySelector('[data-newsletter-local-status]');
    const fieldError = card.querySelector('.newsletter-card__field-error');

    if (!form || !email || !button || !buttonLabel || !localStatus) return;

    form.addEventListener('submit', (event) => {
      const value = String(email.value || '').trim();
      const looksLikeEmail = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(value);

      localStatus.hidden = true;
      button.removeAttribute('data-state');
      buttonLabel.textContent = button.dataset.defaultLabel || buttonLabel.textContent;

      if (!looksLikeEmail) {
        event.preventDefault();
        if (fieldError) fieldError.textContent = window.EMAIL_INVALID_MESSAGE;
        return;
      }

      if (fieldError) fieldError.textContent = '';
      button.setAttribute('data-state', 'sending');
      buttonLabel.textContent = button.dataset.sendingLabel || 'Enviando...';

      window.setTimeout(() => {
        const errorMessage = card.querySelector('#error-message');
        const fieldErrorText = fieldError?.textContent?.trim() || '';
        const errorVisible = errorMessage
          ? window.getComputedStyle(errorMessage).display !== 'none' && Boolean(errorMessage.textContent?.trim())
          : false;

        if (fieldErrorText || errorVisible) {
          button.removeAttribute('data-state');
          buttonLabel.textContent = button.dataset.defaultLabel || buttonLabel.textContent;
          return;
        }

        localStatus.hidden = false;
        button.removeAttribute('data-state');
        buttonLabel.textContent = button.dataset.defaultLabel || buttonLabel.textContent;
        email.value = '';
      }, 2200);
    });
  });
</script>
<script defer src="https://sibforms.com/forms/end-form/build/main.js"></script>
